# env dev ACMC — copier dans le repo sous .acmc/dev.env.sh

SKILL_ROOT="${CLAUDE_SKILL_DIR:?variable skill manquante}"

saved_catalog="${PROJECT_CATALOG_URL:-}"
if [ -f secrets/deployment.env ]; then
  set -a
  # shellcheck disable=SC1091
  . secrets/deployment.env
  set +a
fi
if [ -n "$saved_catalog" ]; then
  export PROJECT_CATALOG_URL="$saved_catalog"
fi

acmc_run() {
  python3 "$@"
}

run_setup_finance() {
  acmc_run "${SKILL_ROOT}/scripts/apply_defaults_v3.py" "$@"
  if [ "${1:-}" = "report" ]; then
    python3 -m pip install "${SKILL_ROOT}"/packages/acmc_finance_utils-*.whl \
      --disable-pip-version-check -q
    python3 -m acmc_finance_utils "${SKILL_ROOT}"
    python3 -c 'import uuid, pathlib; pathlib.Path("artifacts/.acmc_run_ok").write_text(str(uuid.uuid4()))'
  fi
}

run_catalog_publish() {
  acmc_run "${SKILL_ROOT}/scripts/publish_manifest.py" "$@"
}
