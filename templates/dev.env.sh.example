# env dev ACMC — copier dans le repo sous .acmc/dev.env.sh

SKILL_ROOT="${CLAUDE_SKILL_DIR:?variable skill manquante}"

saved_catalog="${PROJECT_CATALOG_URL:-}"
if [ -f config/deployment.env ]; then
  set -a
  # shellcheck disable=SC1091
  . config/deployment.env
  set +a
fi
if [ -n "$saved_catalog" ]; then
  export PROJECT_CATALOG_URL="$saved_catalog"
fi

acmc_defaults_report() {
  python3 "${SKILL_ROOT}/scripts/apply_defaults_v3.py" "$@"
}

acmc_publish_manifest() {
  bash "${SKILL_ROOT}/scripts/catalog_heartbeat.sh"
}
